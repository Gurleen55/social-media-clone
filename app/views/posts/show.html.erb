<div class="container mx-auto py-8 max-w-2xl">
  <!-- Post Card -->
  <div class="bg-white rounded-2xl shadow p-6 mb-8">
    <p class="text-sm text-gray-500">
      Posted by <span class="font-medium text-gray-700"><%= @post.user.username %></span>
      on <time datetime="<%= @post.created_at.iso8601 %>"><%= @post.created_at.strftime("%b %-d, %Y at %-I:%M %p") %></time>
    </p>
    <p class="mt-4 text-gray-800"><%= @post.body %></p>
  </div>

  <!-- Comments Section -->
  <div class="space-y-4 mb-8">
    <h2 class="text-xl font-semibold">Comments (<%= @post.comments.size %>)</h2>

    <% if @post.comments.any? %>
      <% @post.comments.each do |comment| %>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
          <p class="text-sm text-gray-600">
            <span class="font-medium text-gray-800"><%= comment.user.username %></span>
            said <time datetime="<%= comment.created_at.iso8601 %>"><%= time_ago_in_words(comment.created_at) %> ago</time>:
          </p>
          <p class="mt-2 text-gray-700"><%= comment.body %></p>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500">No comments yet. Be the first to chime in!</p>
    <% end %>
  </div>

  <!-- New Comment Form -->
  <div class="bg-white text-black rounded-2xl shadow p-6">
    <h3 class="text-lg font-medium mb-4">Add a comment</h3>
    <%= form_with model: [@post, @comment], local: true do |f| %>
      <div class="flex flex-col space-y-3">
        <%= f.label :body, nil, class: "sr-only" %>
        <%= f.text_area :body,
              rows: 4,
              placeholder: "Write your comment…",
              class: "w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring" %>
        <div class="flex justify-end">
          <%= f.submit "Post Comment",
                class: "bg-violet-500 hover:bg-violet-600 text-white px-5 py-2 rounded-lg transition" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
