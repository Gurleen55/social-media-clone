<div class="max-w-md mx-auto mt-10 p-6 text-black bg-white rounded-lg shadow-lg">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-2xl font-bold">Sign up</h2>
    <%= link_to "Log in", new_user_session_path, class: "text-blue-500 hover:underline" %>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-4") do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block font-semibold mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "border rounded p-2 w-full" %>
    </div>

    <div>
      <%= f.label :username, class: "block font-semibold mb-1" %>
      <%= f.text_field :username, autofocus: true, class: "border rounded p-2 w-full" %>
    </div>

    <div>
      <%= f.label :password, class: "block font-semibold mb-1" %>
      <% if @minimum_password_length %>
        <em class="text-sm text-gray-600">(<%= @minimum_password_length %> characters minimum)</em>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "border rounded p-2 w-full" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block font-semibold mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "border rounded p-2 w-full" %>
    </div>

    <div class="mt-4">
      <%= f.submit "Sign up", class: "bg-blue-500 text-white font-bold py-2 px-4 rounded-lg w-full hover:bg-blue-600" %>
    </div>
  <% end %>

  <div class="mt-4 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>
