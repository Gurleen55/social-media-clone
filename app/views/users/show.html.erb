

<%# ─────────────────────────────────────────────────────── %>
<%# 2) Page container %>
<%# ─────────────────────────────────────────────────────── %>
<div class="bg-gray-900 min-h-screen py-8 px-4">
  <div class="max-w-4xl mx-auto space-y-8">

    <%# ─────────────────────────────────────────────────── %>
    <%#  A) Profile header block (no avatar) %>
    <%# ─────────────────────────────────────────────────── %>
    <div class="bg-white rounded-lg shadow p-6 flex items-center">
      <div class="flex-1">
        <h2 class="text-3xl font-semibold text-gray-800 mb-1"><%= @user.username %></h2>
        <div class="flex space-x-6 text-gray-600">
          <span><strong><%= @posts.size %></strong> Posts</span>
          <span><strong><%= @followers.size %></strong> Followers</span>
          <span><strong><%= @following.size %></strong> Following</span>
        </div>
      </div>
      <div>
        <% if current_user == @user %>
            <%= link_to "Edit Profile", edit_user_registration_path,
                    class: "bg-cyan-200 text-cyan-800 py-2 px-4 rounded hover:bg-cyan-300" %>
        <% end %>
      </div>
    </div>

    <%# ─────────────────────────────────────────────────── %>
    <%#  B) Your Posts %>
    <%# ─────────────────────────────────────────────────── %>
    <section>
      <h3 class="text-2xl font-bold text-gray-200 mb-4">Your Posts</h3>
      <div class="space-y-6">
        <% @posts.each do |post| %>
          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex justify-between items-center mb-4">
              <div>
                <p class="text-sm text-gray-500">Posted by</p>
                <%= link_to post.user.username, user_path(post.user), class: "font-medium text-lg text-gray-800" %>
              </div>
              <% if current_user %>
                <%= link_to "New Comment", new_post_comment_path(post),
                          class: "bg-purple-200 text-purple-800 py-2 px-4 rounded hover:bg-purple-300" %>
                <% end %>
            </div>

            <p class="italic text-gray-700 mb-4"><%= post.body %></p>

            <div class="flex justify-between items-center">
              <div class="text-sm text-gray-600">
                <%= pluralize(post.comments.size, "Comment") %>
              </div>
              <div class="flex space-x-2">
                <% if current_user == @user %>
                  <%= link_to "View comments", post_comments_path(post),
                            class: "bg-blue-200 text-blue-800 py-2 px-4 rounded hover:bg-blue-300" %>
                <%= link_to "Edit post", edit_post_path(post),
                            class: "bg-cyan-200 text-cyan-800 py-2 px-4 rounded hover:bg-cyan-300" %>
                <%= link_to "Delete post", post_path(post),
                            method: :delete,
                            data: { confirm: "Are you sure?" },
                            class: "bg-red-200 text-red-800 py-2 px-4 rounded hover:bg-red-300" %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <%# ─────────────────────────────────────────────────── %>
    <%#  C) Followers & Following lists %>
    <%# ─────────────────────────────────────────────────── %>
    <section class="grid grid-cols-2 gap-6">
      <div class="bg-white rounded-lg shadow p-6">
        <h4 class="font-semibold text-gray-800 mb-3">Followers (<%= @followers.size %>)</h4>
        <ul class="space-y-2 max-h-48 overflow-auto">
          <% @followers.each do |f| %>
            <li>
              <%= link_to f.username, user_path(f), class: "text-gray-700 hover:underline" %>
              (<%= f.posts.size %> posts)
            </li>
          <% end %>
        </ul>
      </div>
      <div class="bg-white rounded-lg shadow p-6">
        <h4 class="font-semibold text-gray-800 mb-3">Following (<%= @following.size %>)</h4>
        <ul class="space-y-2 max-h-48 overflow-auto">
          <% @following.each do |f| %>
            <li>
              <%= link_to f.username, user_path(f), class: "text-gray-700 hover:underline" %>
              (<%= f.posts.size %> posts)
            </li>
          <% end %>
        </ul>
      </div>
    </section>

  </div>
</div>
