<div data-testid="user_<%= user.id %>" class="flex justify-between bg-white border text-black border-gray-300 rounded-lg p-4 shadow-sm mb-4">
    <%= user.username %>
    <% unless current_user.following?(user) %>
        <%= button_to "Follow", follow_user_path(user), method: :post, class: "bg-cyan-500 hover:bg-cyan-600 text-white font-semibold py-2 px-4 rounded-xl shadow" %>
    <% else %>
        <%= button_to "Unfollow", unfollow_user_path(user),method: :post, class: "bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-4 rounded-xl shadow" %>
    <% end %>
</div>